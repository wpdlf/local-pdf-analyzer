{
  "name": "summary-lecture-material",
  "version": "0.1.0",
  "description": "PDF 대학교 강의자료 요약 데스크톱 앱",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^4.1.0"
  },
  "build": {
    "appId": "com.jjw.summary-lecture-material",
    "productName": "강의자료 요약기",
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": "portable"
    },
    "forceCodeSigning": false,
    "mac": {
      "target": "dmg"
    }
  }
}
