{
  "name": "summary-lecture-material",
  "version": "0.24.4",
  "description": "PDF 자료 분석 데스크톱 앱",
  "license": "MIT",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=20.11 <25",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && node scripts/postbuild.mjs",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.3"
  },
  "//testingPinPolicy": "R37 P3 (v0.18.23): 테스트 인프라 6종(@testing-library/* 3개, happy-dom, vitest, @vitest/coverage-v8)은 정확 핀. 사유: 테스팅 도구의 patch/minor 업데이트가 assertion 동작·매처·DOM 시뮬레이션 세부를 조용히 바꿔 CI 가 그린인 채로 false negative(또는 false positive) 가 발생한 전례가 다수. 본 repo 는 dependabot 미사용으로 수동 bump 라운드에서만 갱신하므로 핀 비용 0. 그 외 deps(electron/vite/react 등)는 SemVer 신뢰가 충분히 검증되어 캐럿 유지.",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "4.1.6",
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "happy-dom": "20.9.0",
    "pdf-lib": "^1.17.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "4.1.6"
  },
  "build": {
    "appId": "com.jjw.summary-lecture-material",
    "productName": "PDF 자료 분석기",
    "files": [
      "out/**/*",
      "!**/*.map"
    ],
    "asarUnpack": [
      "out/renderer/cmaps/**"
    ],
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      }
    ],
    "icon": "resources/icon.png",
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png",
      "artifactName": "Local-PDF-Analyzer-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PDF 자료 분석기"
    },
    "forceCodeSigning": false,
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.png",
      "artifactName": "Local-PDF-Analyzer-${version}.${ext}"
    }
  }
}
